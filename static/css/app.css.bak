/* Leasure — early HTML aesthetic */

:root {
    --bg: #f5f5f0;
    --text: #1a1a1a;
    --text-muted: #666;
    --link: #0000ee;
    --link-visited: #551a8b;
    --border: #ccc;
    --border-light: #ddd;
    --accent: #0000ee;
    --success: #006400;
    --error: #8b0000;
    --code-bg: #e8e8e0;
}

* { box-sizing: border-box; }

body {
    font-family: "Times New Roman", Georgia, serif;
    background: var(--bg);
    color: var(--text);
    margin: 0;
    padding: 0;
    font-size: 16px;
    line-height: 1.6;
}

a { color: var(--link); }
a:visited { color: var(--link-visited); }
a:hover { color: var(--error); }

hr {
    border: none;
    border-top: 1px solid var(--border);
    margin: 1rem 0;
}

/* Layout */
.site-header {
    background: #fff;
    border-bottom: 2px solid var(--text);
    padding: 0.5rem 1rem;
    display: flex;
    justify-content: space-between;
    align-items: center;
}

.site-header h1 {
    font-size: 1.2rem;
    margin: 0;
    font-weight: normal;
    letter-spacing: 0.1em;
    text-transform: uppercase;
}

.site-nav {
    display: flex;
    gap: 0.5rem;
    font-size: 0.9rem;
}

.site-nav a {
    text-decoration: none;
    padding: 0.2rem 0.5rem;
    border: 1px solid transparent;
}

.site-nav a:hover,
.site-nav a.active {
    border: 1px solid var(--text);
    background: var(--bg);
}

.container {
    max-width: 960px;
    margin: 0 auto;
    padding: 1rem;
}

/* Status bar — always visible */
#status-bar {
    background: #fff;
    border-bottom: 1px solid var(--border);
    padding: 0.3rem 1rem;
    font-size: 0.8rem;
    color: var(--text-muted);
    display: flex;
    justify-content: space-between;
    font-family: "Courier New", monospace;
}

#status-bar .stat { margin-right: 1.5rem; }
#status-bar .active { color: var(--success); font-weight: bold; }

/* Section headers */
h2 {
    font-size: 1.1rem;
    font-weight: normal;
    border-bottom: 1px solid var(--border);
    padding-bottom: 0.3rem;
    margin-top: 1.5rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
}

h3 {
    font-size: 1rem;
    margin: 0.5rem 0;
}

/* Album grid — LP roulette style */
.album-grid {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    padding: 0.5rem 0;
}

.album-card {
    width: 120px;
    cursor: pointer;
    text-align: center;
    padding: 0.5rem;
    border: 1px solid transparent;
    transition: border-color 0.1s;
}

.album-card:hover {
    border-color: var(--border);
    background: #fff;
}

.album-card img {
    width: 100px;
    height: 100px;
    border-radius: 50%;
    object-fit: cover;
    border: 2px solid var(--text);
    box-shadow: inset 0 0 0 20px rgba(0,0,0,0.03);
    transition: transform 0.3s;
}

.album-card:hover img {
    transform: rotate(15deg);
}

/* LP center hole effect */
.album-card img {
    background: radial-gradient(circle at center, var(--text) 8%, transparent 8.5%);
}

.album-card h4 {
    font-size: 0.75rem;
    margin: 0.3rem 0 0;
    font-weight: normal;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
    font-family: "Courier New", monospace;
}

.album-card p {
    margin: 0;
    font-size: 0.7rem;
    color: var(--text-muted);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
}

/* Track rows */
.track-row {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.2rem 0;
    border-bottom: 1px dotted var(--border-light);
    font-size: 0.85rem;
}

.track-row:hover { background: #fff; }

.track-num {
    width: 1.5rem;
    text-align: right;
    color: var(--text-muted);
    font-family: "Courier New", monospace;
    font-size: 0.8rem;
}

.track-info { flex: 1; min-width: 0; }

.track-title {
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
}

.track-artist {
    font-size: 0.8rem;
    color: var(--text-muted);
}

.track-duration {
    color: var(--text-muted);
    font-size: 0.8rem;
    font-family: "Courier New", monospace;
}

/* Badges */
.badge {
    display: inline-block;
    padding: 0 0.4rem;
    font-size: 0.7rem;
    font-family: "Courier New", monospace;
    border: 1px solid;
    text-transform: uppercase;
}

.badge-done { border-color: var(--success); color: var(--success); }
.badge-downloading { border-color: var(--accent); color: var(--accent); }
.badge-error { border-color: var(--error); color: var(--error); }
.badge-lossless { border-color: #b8860b; color: #b8860b; }
.badge-mp3 { border-color: var(--text-muted); color: var(--text-muted); }

/* Buttons */
button, .btn {
    font-family: "Courier New", monospace;
    font-size: 0.8rem;
    background: #fff;
    border: 1px solid var(--text);
    padding: 0.3rem 0.8rem;
    cursor: pointer;
    color: var(--text);
}

button:hover, .btn:hover {
    background: var(--text);
    color: #fff;
}

button:disabled {
    opacity: 0.5;
    cursor: wait;
}

button.outline {
    background: transparent;
    border: 1px solid var(--border);
    color: var(--text-muted);
}

button.outline:hover {
    border-color: var(--text);
    color: var(--text);
    background: #fff;
}

/* Forms */
input, select, textarea {
    font-family: "Courier New", monospace;
    font-size: 0.85rem;
    border: 1px solid var(--border);
    padding: 0.3rem 0.5rem;
    background: #fff;
}

input:focus, select:focus, textarea:focus {
    outline: 1px solid var(--accent);
    border-color: var(--accent);
}

select.format-select {
    display: inline-block;
    width: auto;
    min-width: 140px;
}

fieldset {
    border: 1px solid var(--border);
    padding: 0.5rem;
    margin: 0;
}

legend {
    font-size: 0.85rem;
    padding: 0 0.3rem;
}

/* Tables */
table {
    width: 100%;
    border-collapse: collapse;
    font-size: 0.85rem;
}

th {
    text-align: left;
    border-bottom: 2px solid var(--text);
    padding: 0.3rem 0.5rem;
    font-weight: normal;
    text-transform: uppercase;
    font-size: 0.75rem;
    letter-spacing: 0.05em;
}

td {
    padding: 0.3rem 0.5rem;
    border-bottom: 1px dotted var(--border-light);
}

/* Progress bar */
progress {
    width: 100%;
    height: 12px;
    border: 1px solid var(--border);
    background: #fff;
}

progress::-webkit-progress-bar { background: #fff; }
progress::-webkit-progress-value { background: var(--text); }
progress::-moz-progress-bar { background: var(--text); }

/* Drive cards */
.drive-card {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.5rem;
    border: 1px solid var(--border);
    margin-bottom: 0.3rem;
    background: #fff;
    font-size: 0.85rem;
}

.drive-letter {
    font-family: "Courier New", monospace;
    font-size: 1.2rem;
    font-weight: bold;
    min-width: 2rem;
}

.drive-info { flex: 1; }
.drive-info small { color: var(--text-muted); }

/* Dialog/Modal */
dialog {
    border: 2px solid var(--text);
    background: var(--bg);
    max-width: 800px;
    width: 90vw;
    max-height: 85vh;
    padding: 0;
}

dialog::backdrop { background: rgba(0,0,0,0.3); }

dialog header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    border-bottom: 1px solid var(--border);
    padding: 0.5rem 1rem;
    background: #fff;
}

dialog header button {
    border: none;
    background: none;
    font-size: 1.2rem;
    cursor: pointer;
}

dialog > article,
dialog > div {
    padding: 1rem;
    overflow-y: auto;
    max-height: calc(85vh - 3rem);
}

/* Queue item */
.queue-item {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.2rem 0;
    border-bottom: 1px dotted var(--border-light);
    font-size: 0.85rem;
}

/* Details/Summary */
details {
    margin: 0.5rem 0;
    border: 1px solid var(--border);
    padding: 0.5rem;
    background: #fff;
}

summary {
    cursor: pointer;
    font-size: 0.9rem;
}

/* Footer */
.site-footer {
    text-align: center;
    padding: 1rem;
    font-size: 0.75rem;
    color: var(--text-muted);
    border-top: 1px solid var(--border);
    margin-top: 2rem;
    font-family: "Courier New", monospace;
}

/* Grid layout */
.grid-2 {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1rem;
}

@media (max-width: 640px) {
    .grid-2 { grid-template-columns: 1fr; }
    .album-card { width: 100px; }
    .album-card img { width: 80px; height: 80px; }
}

/* Marquee-style LP carousel */
.lp-carousel {
    overflow: hidden;
    white-space: nowrap;
    border-top: 1px solid var(--border);
    border-bottom: 1px solid var(--border);
    padding: 0.5rem 0;
    margin: 0.5rem 0;
}

.lp-carousel-inner {
    display: inline-flex;
    gap: 1rem;
    animation: scroll-lp 30s linear infinite;
}

.lp-carousel img {
    width: 60px;
    height: 60px;
    border-radius: 50%;
    border: 1px solid var(--text);
    object-fit: cover;
    animation: spin-lp 4s linear infinite;
}

@keyframes scroll-lp {
    from { transform: translateX(0); }
    to { transform: translateX(-50%); }
}

@keyframes spin-lp {
    from { transform: rotate(0deg); }
    to { transform: rotate(360deg); }
}
